{
  "skill": "ux-flow-auditor",
  "version": "1.0.0",
  "tools": [
    {
      "name": "init_ux_flows",
      "description": "Scaffold .heyeddi/docs/ux-flows.md and example flow definition.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/init_ux_flows.py",
      "readonly": false
    },
    {
      "name": "trace_flow",
      "description": "Run Playwright task flow; write click metrics to .heyeddi/docs/ux-flows/.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string", "description": "Flow id matching .flow.json basename" },
          "project_root": { "type": "string" },
          "check": { "type": "boolean", "description": "Exit non-zero if over click budget or step fails" }
        },
        "required": ["task_id", "project_root"]
      },
      "script": "scripts/trace_flow.py",
      "readonly": true
    }
  ]
}
