{
  "skill": "flutter-engineering",
  "version": "1.0.0",
  "tools": [
    {
      "name": "audit_scaffold",
      "description": "Audit Flutter, FastAPI, and Firebase layers; returns per-stack gaps.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/audit_scaffold.py",
      "readonly": true
    },
    {
      "name": "scaffold_stack",
      "description": "Scaffold stacks: auto, flutter, fastapi, firebase, or full.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "stack": {
            "type": "string",
            "enum": ["auto", "flutter", "fastapi", "firebase", "full"]
          },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_stack.py",
      "readonly": false
    },
    {
      "name": "scaffold_flutter",
      "description": "Flutter + Riverpod + go_router scaffold only.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_flutter.py",
      "readonly": false
    },
    {
      "name": "ensure_flutter",
      "description": "flutter pub get for frontend.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/ensure_flutter.py",
      "readonly": false
    },
    {
      "name": "dev_server_info",
      "description": "Commands and URLs for Flutter web, FastAPI, Firebase emulators.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "route": { "type": "string" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/dev_server_info.py",
      "readonly": true
    },
    {
      "name": "run_tests",
      "description": "Run flutter test.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/run_tests.py",
      "readonly": true
    },
    {
      "name": "verify_build",
      "description": "flutter analyze and build web.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "skip_build": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/verify_build.py",
      "readonly": true
    },
    {
      "name": "run_backend_tests",
      "description": "Run pytest in backend/.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/run_backend_tests.py",
      "readonly": true
    }
  ]
}
