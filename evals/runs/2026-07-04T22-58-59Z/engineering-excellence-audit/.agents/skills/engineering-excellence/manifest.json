{
  "skill": "engineering-excellence",
  "version": "1.0.0",
  "tools": [
    {
      "name": "init_engineering_docs",
      "description": "Scaffold .heyeddi/docs/engineering/ (architecture, reuse catalog, decisions).",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string", "description": "Workspace root path" },
          "force": { "type": "boolean", "description": "Overwrite stub templates" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/init_engineering_docs.py",
      "readonly": false
    },
    {
      "name": "audit_engineering",
      "description": "Scan for KISS/YAGNI/SOLID/testability signals; write engineering-audit report.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean", "description": "Exit non-zero on errors" },
          "strict": { "type": "boolean", "description": "Exit non-zero on warnings too" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/audit_engineering.py",
      "readonly": true
    },
    {
      "name": "append_decision",
      "description": "Append an engineering ADR to .heyeddi/docs/engineering/decisions.md.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "title": { "type": "string" },
          "context": { "type": "string" },
          "decision": { "type": "string" },
          "consequences": { "type": "string" }
        },
        "required": ["project_root", "title", "context", "decision"]
      },
      "script": "scripts/append_decision.py",
      "readonly": false
    }
  ]
}
