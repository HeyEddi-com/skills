{
  "task_id": "update-profile",
  "goal": "User updates display name and saves profile",
  "start_route": "/settings",
  "max_clicks": 4,
  "viewport_width": 1440,
  "steps": [
    {
      "action": "expect",
      "selector": ".settings input, .settings .p-inputtext",
      "label": "Profile form visible"
    },
    {
      "action": "fill",
      "selector": ".settings input, .settings .p-inputtext >> nth=0",
      "value": "Alex Rivera",
      "label": "Edit display name"
    },
    {
      "action": "click",
      "selector": ".settings__save button, .settings button:has-text('Save')",
      "label": "Save changes"
    }
  ]
}
