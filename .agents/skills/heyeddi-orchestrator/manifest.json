{
  "skill": "heyeddi-orchestrator",
  "version": "2.0.0",
  "tools": [
    {
      "name": "sync",
      "description": "Full .heyeddi/ sync — migrate skill names, refresh skills index, init workflow if missing.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "hub_root": { "type": "string" },
          "force_migrate": { "type": "boolean" },
          "skip_workflow": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/sync.py",
      "readonly": false
    },
    {
      "name": "migrate_heyeddi",
      "description": "Migrate deprecated v1 skill names in .heyeddi/ to v2 heyeddi-* canonical names.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "hub_root": { "type": "string" },
          "dry_run": { "type": "boolean" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/migrate_heyeddi.py",
      "readonly": false
    },
    {
      "name": "write_skills_index",
      "description": "Scan installed skills and write .heyeddi/skills-index.json + skills-index.md.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "hub_root": {
            "type": "string"
          },
          "dry_run": {
            "type": "boolean"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/write_skills_index.py",
      "readonly": false
    },
    {
      "name": "load_catalog",
      "description": "Load skills catalog from .heyeddi/skills-index.json (or scan+write if missing).",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "hub_root": {
            "type": "string"
          },
          "refresh": {
            "type": "boolean"
          },
          "no_write": {
            "type": "boolean"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/load_catalog.py",
      "readonly": true
    },
    {
      "name": "suggest_skills",
      "description": "Rank skills for a user prompt using cached index; merges skill-routing.json when present.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "user_prompt": {
            "type": "string"
          },
          "prompt_file": {
            "type": "string"
          },
          "hub_root": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "refresh": {
            "type": "boolean"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/suggest_skills.py",
      "readonly": true
    },
    {
      "name": "init_workflow_sync",
      "description": "Scaffold .heyeddi/docs/workflow/ for product+UX+design cross-pillar opinions.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "force": {
            "type": "boolean"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/init_workflow_sync.py",
      "readonly": false
    },
    {
      "name": "load_workflow_context",
      "description": "Load sibling pillar opinions and checklist for a route.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "feature": {
            "type": "string"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/load_workflow_context.py",
      "readonly": true
    },
    {
      "name": "append_pillar_opinion",
      "description": "Record pillar opinion and request sibling product/UX/design responses.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string"
          },
          "pillar": {
            "type": "string",
            "enum": [
              "product",
              "ux",
              "design"
            ]
          },
          "route": {
            "type": "string"
          },
          "opinion": {
            "type": "string"
          },
          "docs_updated": {
            "type": "string"
          },
          "request_pillars": {
            "type": "string"
          },
          "feature": {
            "type": "string"
          }
        },
        "required": [
          "project_root",
          "pillar",
          "route",
          "opinion"
        ]
      },
      "script": "scripts/append_pillar_opinion.py",
      "readonly": false
    }
  ]
}
