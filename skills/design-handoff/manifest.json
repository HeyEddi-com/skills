{
  "skill": "design-handoff",
  "version": "1.2.0",
  "tools": [
    {
      "name": "load_handoff",
      "description": "Resolve screenshots, mockup-brief.md, and notes into a normalized handoff brief.",
      "parameters": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "description": "Target route e.g. /settings"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "feature": {
            "type": "string",
            "description": "Feature folder under designs/"
          }
        },
        "required": [
          "route",
          "project_root"
        ]
      },
      "script": "scripts/load_handoff.py",
      "readonly": true
    },
    {
      "name": "describe_handoff",
      "description": "Validate mockup-brief.md and sync layout sections into design.md.",
      "parameters": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "description": "Target route e.g. /settings"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "feature": {
            "type": "string",
            "description": "Feature folder under designs/"
          },
          "sync_design": {
            "type": "boolean",
            "description": "Merge brief into .heyeddi/design.md"
          },
          "check": {
            "type": "boolean",
            "description": "Fail if brief missing or incomplete"
          }
        },
        "required": [
          "route",
          "project_root"
        ]
      },
      "script": "scripts/describe_handoff.py",
      "readonly": false
    },
    {
      "name": "verify_handoff",
      "description": "Verify Vue/tokens match mockup-brief Implementation spec.",
      "parameters": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "description": "Target route e.g. /settings"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "feature": {
            "type": "string",
            "description": "Feature folder under designs/"
          },
          "phase": {
            "type": "string",
            "enum": [
              "shell",
              "full"
            ],
            "description": "shell after layout components; full after route"
          },
          "check": {
            "type": "boolean",
            "description": "Exit non-zero if verification fails"
          }
        },
        "required": [
          "route",
          "project_root"
        ]
      },
      "script": "scripts/verify_handoff.py",
      "readonly": true
    },
    {
      "name": "verify_tokens",
      "description": "Detect circular CSS custom-property aliases in tokens.css.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "tokens_path": {
            "type": "string",
            "description": "Relative path to tokens.css (default src/styles/tokens.css)"
          },
          "check": {
            "type": "boolean",
            "description": "Exit non-zero if verification fails"
          }
        },
        "required": []
      },
      "script": "scripts/verify_tokens.py",
      "readonly": true
    },
    {
      "name": "verify_theme",
      "description": "Verify light/dark semantic tokens and PrimeVue surface alignment.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "tokens_path": {
            "type": "string",
            "description": "Relative path to tokens.css"
          },
          "check": {
            "type": "boolean",
            "description": "Exit non-zero if verification fails"
          }
        },
        "required": []
      },
      "script": "scripts/verify_theme.py",
      "readonly": true
    }
  ],
  "alias_of": "heyeddi-handoff",
  "deprecated": true
}
