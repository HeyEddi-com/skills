{
  "skill": "project-engineering",
  "version": "1.1.0",
  "tools": [
    {
      "name": "audit_scaffold",
      "description": "Audit Vue, FastAPI, and Firebase layers; returns per-stack gaps and next_steps.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/audit_scaffold.py",
      "readonly": true
    },
    {
      "name": "scaffold_stack",
      "description": "Scaffold stacks: auto, vue, fastapi, firebase, or full. Prefer over scaffold_vue when backends matter.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "stack": {
            "type": "string",
            "enum": ["auto", "vue", "fastapi", "firebase", "full"],
            "description": "default auto"
          },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_stack.py",
      "readonly": false
    },
    {
      "name": "scaffold_vue",
      "description": "Vue + Vite + Vitest only.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_vue.py",
      "readonly": false
    },
    {
      "name": "scaffold_fastapi",
      "description": "FastAPI backend under backend/ plus root openapi.json.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_fastapi.py",
      "readonly": false
    },
    {
      "name": "scaffold_firebase",
      "description": "firebase.json, firestore rules, emulator config, env template.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/scaffold_firebase.py",
      "readonly": false
    },
    {
      "name": "ensure_npm",
      "description": "npm ci or npm install for frontend.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/ensure_npm.py",
      "readonly": false
    },
    {
      "name": "ensure_python",
      "description": "Poetry or pip install for backend/ FastAPI deps.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/ensure_python.py",
      "readonly": false
    },
    {
      "name": "dev_server_info",
      "description": "Commands and URLs for Vue dev, FastAPI uvicorn, Firebase emulators.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "route": { "type": "string" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/dev_server_info.py",
      "readonly": true
    },
    {
      "name": "run_tests",
      "description": "Run frontend npm test.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "watch": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/run_tests.py",
      "readonly": true
    },
    {
      "name": "run_backend_tests",
      "description": "Run pytest in backend/.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/run_backend_tests.py",
      "readonly": true
    },
    {
      "name": "audit_dependencies",
      "description": "Check lockfile, node_modules, stub scripts, outdated major deps.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "max_major_behind": { "type": "integer" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/audit_dependencies.py",
      "readonly": true
    },
    {
      "name": "write_test_stub",
      "description": "Vitest spec for a Vue file.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "path": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root", "path"]
      },
      "script": "scripts/write_test_stub.py",
      "readonly": false
    }
  ]
}
