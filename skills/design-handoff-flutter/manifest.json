{
  "skill": "design-handoff-flutter",
  "version": "1.1.0",
  "tools": [
    {
      "name": "load_handoff",
      "description": "Load Flutter handoff brief for a route.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "route": { "type": "string" },
          "feature": { "type": "string" }
        },
        "required": ["project_root", "route"]
      },
      "script": "scripts/load_handoff.py",
      "readonly": true
    },
    {
      "name": "describe_handoff",
      "description": "Validate mockup-brief and sync design.md.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "route": { "type": "string" },
          "feature": { "type": "string" },
          "check": { "type": "boolean" },
          "sync_design": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "route"]
      },
      "script": "scripts/describe_handoff.py",
      "readonly": false
    },
    {
      "name": "verify_handoff",
      "description": "Verify Flutter shell and route widgets match brief Implementation spec.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "route": { "type": "string" },
          "phase": { "type": "string", "enum": ["shell", "full"] },
          "check": { "type": "boolean" }
        },
        "required": ["project_root", "route"]
      },
      "script": "scripts/verify_handoff.py",
      "readonly": true
    },
    {
      "name": "verify_tokens",
      "description": "Verify lib/theme/app_theme.dart Material 3 token setup.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "theme_path": { "type": "string" },
          "check": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/verify_tokens.py",
      "readonly": true
    },
    {
      "name": "verify_theme",
      "description": "Verify Flutter light/dark theme coherence and router wiring.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/verify_theme.py",
      "readonly": true
    }
  ]
}
