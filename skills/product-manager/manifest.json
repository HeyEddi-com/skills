{
  "skill": "product-manager",
  "version": "1.0.0",
  "tools": [
    {
      "name": "init_product_docs",
      "description": "Scaffold .heyeddi/docs/product/ backlog, features README, reviews index.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/init_product_docs.py",
      "readonly": false
    },
    {
      "name": "load_product_context",
      "description": "Snapshot product.md, feature specs, code routes, gaps, delegation hints.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/load_product_context.py",
      "readonly": true
    },
    {
      "name": "audit_product",
      "description": "Audit product.md and feature specs for PM completeness.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/audit_product.py",
      "readonly": true
    },
    {
      "name": "write_feature_spec",
      "description": "Write features/<slug>.md from JSON — user stories and acceptance criteria.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "json": { "type": "string" },
          "slug": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "json"]
      },
      "script": "scripts/write_feature_spec.py",
      "readonly": false
    },
    {
      "name": "check_features",
      "description": "Compare product routes to Vue router/views; detect placeholders; PM usefulness questions.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/check_features.py",
      "readonly": true
    },
    {
      "name": "write_review_plan",
      "description": "Scaffold holistic review with delegation slots for UX, design, visual, engineering.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "title": { "type": "string" },
          "scope": { "type": "string", "enum": ["full", "route", "release"] },
          "route": { "type": "string" },
          "force": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/write_review_plan.py",
      "readonly": false
    },
    {
      "name": "verify_product",
      "description": "Run audit_product + check_features; --check exits 1 on blockers.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean" },
          "skip_features": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/verify_product.py",
      "readonly": true
    }
  ]
}
