{
  "skill": "dart-type-bridger",
  "version": "1.0.0",
  "tools": [
    {
      "name": "sync_openapi",
      "description": "Sync OpenAPI schema to Dart model stub under lib/models/.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "url": { "type": "string" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/sync_openapi.py",
      "readonly": false
    },
    {
      "name": "fetch_firestore_schema",
      "description": "Read Firestore rules / schema hints.",
      "parameters": {
        "type": "object",
        "properties": { "project_root": { "type": "string" } },
        "required": ["project_root"]
      },
      "script": "scripts/fetch_firestore_schema.py",
      "readonly": true
    }
  ]
}
