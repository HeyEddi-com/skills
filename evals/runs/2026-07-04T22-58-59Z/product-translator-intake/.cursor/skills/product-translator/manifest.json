{
  "skill": "product-translator",
  "version": "1.1.0",
  "tools": [
    {
      "name": "load_intake",
      "description": "Load user prompt, product, design folders, intake gaps, workflow checklist.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "user_prompt": { "type": "string" },
          "prompt_file": { "type": "string" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/load_intake.py",
      "readonly": true
    },
    {
      "name": "write_product",
      "description": "Validate JSON and write .heyeddi/product.md + docs/intake/product-translation.json. Required: personas, route_intent, voice, competitors.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "json": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "json"]
      },
      "script": "scripts/write_product.py",
      "readonly": false
    },
    {
      "name": "write_translation",
      "description": "Write docs/intake/translation-<date>.md session record.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "user_prompt": { "type": "string" },
          "summary": { "type": "string" },
          "decisions": { "type": "string" },
          "open_questions": { "type": "string" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "user_prompt", "summary"]
      },
      "script": "scripts/write_translation.py",
      "readonly": false
    },
    {
      "name": "ingest_mockups",
      "description": "Copy user mockup images into .heyeddi/designs/<feature>/.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "feature": { "type": "string" },
          "route": { "type": "string" },
          "app_name": { "type": "string" },
          "source": { "type": "array", "items": { "type": "string" } },
          "source_dir": { "type": "string" }
        },
        "required": ["project_root", "feature"]
      },
      "script": "scripts/ingest_mockups.py",
      "readonly": false
    },
    {
      "name": "generate_mockups",
      "description": "Generate professional layout PNGs when user did not supply images.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "feature": { "type": "string" },
          "preset": { "type": "string" },
          "route": { "type": "string" },
          "app_name": { "type": "string" },
          "page_title": { "type": "string" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/generate_mockups.py",
      "readonly": false
    },
    {
      "name": "seed_brief",
      "description": "Seed mockup-brief.md with Audience block + Implementation spec.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "feature": { "type": "string" },
          "route": { "type": "string" },
          "app_name": { "type": "string" },
          "designer_read": { "type": "string" },
          "force": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "feature"]
      },
      "script": "scripts/seed_brief.py",
      "readonly": false
    },
    {
      "name": "build_routing",
      "description": "Build skill-routing.json from product-translation.json and design folders.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "json": { "type": "string" },
          "write": { "type": "boolean" },
          "save_input": { "type": "boolean" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/build_routing.py",
      "readonly": false
    },
    {
      "name": "write_routing",
      "description": "Write skill-routing.json from explicit JSON (override build_routing).",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "json": { "type": "string" },
          "dry_run": { "type": "boolean" }
        },
        "required": ["project_root", "json"]
      },
      "script": "scripts/write_routing.py",
      "readonly": false
    },
    {
      "name": "verify_intake",
      "description": "Verify all translator artifacts; use --check for exit 1 on failure.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": { "type": "string" },
          "check": { "type": "boolean" }
        },
        "required": ["project_root"]
      },
      "script": "scripts/verify_intake.py",
      "readonly": true
    }
  ]
}
