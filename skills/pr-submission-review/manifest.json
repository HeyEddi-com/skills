{
  "skill": "pr-submission-review",
  "version": "1.0.0",
  "tools": [
    {
      "name": "fetch_pr_context",
      "description": "Fetch PR metadata, committed diff stats, and changed file list (gh or fixture).",
      "parameters": {
        "type": "object",
        "properties": {
          "pr": {
            "type": "integer",
            "description": "Pull request number"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "fixture": {
            "type": "string",
            "description": "Optional fixture JSON path (eval/CI without gh)"
          }
        },
        "required": ["pr", "project_root"]
      },
      "script": "scripts/fetch_pr_context.py",
      "readonly": true
    },
    {
      "name": "check_doc_drift",
      "description": "Detect docs not updated for routes/files changed in the PR.",
      "parameters": {
        "type": "object",
        "properties": {
          "pr": {
            "type": "integer",
            "description": "Pull request number"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "context": {
            "type": "string",
            "description": "Path to fetch_pr_context JSON output"
          },
          "fixture": {
            "type": "string",
            "description": "Optional fixture for fetch_pr_context when context omitted"
          }
        },
        "required": ["pr", "project_root"]
      },
      "script": "scripts/check_doc_drift.py",
      "readonly": true
    },
    {
      "name": "audit_pr_changes",
      "description": "Engineering and test-coverage signals scoped to PR changed files only.",
      "parameters": {
        "type": "object",
        "properties": {
          "pr": {
            "type": "integer",
            "description": "Pull request number"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "context": {
            "type": "string",
            "description": "Path to fetch_pr_context JSON output"
          },
          "fixture": {
            "type": "string",
            "description": "Optional fixture for fetch_pr_context when context omitted"
          }
        },
        "required": ["pr", "project_root"]
      },
      "script": "scripts/audit_pr_changes.py",
      "readonly": true
    },
    {
      "name": "write_pr_review",
      "description": "Write or update .heyeddi/docs/pr-N-review.md from tool outputs.",
      "parameters": {
        "type": "object",
        "properties": {
          "pr": {
            "type": "integer",
            "description": "Pull request number"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "context": {
            "type": "string",
            "description": "Path to fetch_pr_context JSON"
          },
          "drift": {
            "type": "string",
            "description": "Path to check_doc_drift JSON"
          },
          "audit": {
            "type": "string",
            "description": "Path to audit_pr_changes JSON"
          },
          "gate": {
            "type": "string",
            "description": "Path to pre_merge_gate markdown report"
          },
          "force": {
            "type": "boolean",
            "description": "Overwrite existing review report"
          }
        },
        "required": ["pr", "project_root"]
      },
      "script": "scripts/write_pr_review.py",
      "readonly": false
    },
    {
      "name": "verify_pr_review",
      "description": "Verify PR review report exists and has required sections.",
      "parameters": {
        "type": "object",
        "properties": {
          "pr": {
            "type": "integer",
            "description": "Pull request number"
          },
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "check": {
            "type": "boolean",
            "description": "Exit 1 when report incomplete"
          }
        },
        "required": ["pr", "project_root"]
      },
      "script": "scripts/verify_pr_review.py",
      "readonly": true
    }
  ]
}
