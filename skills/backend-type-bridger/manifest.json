{
  "skill": "backend-type-bridger",
  "version": "1.0.0",
  "tools": [
    {
      "name": "sync_openapi",
      "description": "Generate TypeScript interfaces from a local openapi.json into src/types/api.ts (no network fetch).",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          },
          "openapi": {
            "type": "string",
            "description": "OpenAPI file relative to project root (default: openapi.json)"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/sync_openapi.py",
      "readonly": false
    },
    {
      "name": "fetch_firestore_schema",
      "description": "Read Firestore rules or schema file for TS type hints.",
      "parameters": {
        "type": "object",
        "properties": {
          "project_root": {
            "type": "string",
            "description": "Workspace root path"
          }
        },
        "required": [
          "project_root"
        ]
      },
      "script": "scripts/fetch_firestore_schema.py",
      "readonly": true
    }
  ]
}
